<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardIlan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Üst Kısım: Kurum ve Uyum -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvKurum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kurum Adı"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/viewUyumRengi"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#059669"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvUyum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="%85 Uyum"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#059669" />
            </LinearLayout>
        </LinearLayout>

        <!-- Pozisyon -->
        <TextView
            android:id="@+id/tvPozisyon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pozisyon"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2563EB"
            android:layout_marginTop="8dp" />

        <!-- Bölüm -->
        <TextView
            android:id="@+id/tvBolum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bölüm"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginTop="4dp" />

        <!-- Şehir ve Kadro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvSehir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Şehir"
                android:textSize="14sp"
                android:textColor="#64748B" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvKadro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kadro"
                android:textSize="12sp"
                android:textColor="#2563EB"
                android:background="#EFF6FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />
        </LinearLayout>

        <!-- Tarih -->
        <TextView
            android:id="@+id/tvTarih"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Son Tarih: 01.01.2024"
            android:textSize="13sp"
            android:textColor="#DC2626"
            android:layout_marginTop="8dp" />

        <!-- Şartlar Özeti -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvKpss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="KPSS: 70"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="#F1F5F9"
                android:padding="6dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvEhliyet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ehliyet: B"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="#F1F5F9"
                android:padding="6dp"
                android:gravity="center"
                android:layout_marginStart="4dp" />

            <TextView
                android:id="@+id/tvYas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Yaş: 18-30"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="#F1F5F9"
                android:padding="6dp"
                android:gravity="center"
                android:layout_marginStart="4dp" />

            <TextView
                android:id="@+id/tvIkamet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="İkamet: Ankara"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="#F1F5F9"
                android:padding="6dp"
                android:gravity="center"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- YENİ: Evrak Teslim Bilgisi -->
        <TextView
            android:id="@+id/tvEvrakTeslim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online Başvuru"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="#F0FDF4"
            android:textColor="#059669"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical" />

        <!-- Butonlar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detayları Gör"
                android:textColor="#FFFFFF"
                app:backgroundTint="#2563EB"
                app:cornerRadius="8dp" />

            <ImageButton
                android:id="@+id/btnFavori"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_save"
                android:tint="#64748B" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
