<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:title="İlan Detayı"
            app:titleTextColor="#1E293B" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Başlık Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvKurum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kurum Adı"
                        android:textSize="16sp"
                        android:textColor="#64748B" />

                    <TextView
                        android:id="@+id/tvPozisyon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pozisyon"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvBolum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bölüm"
                        android:textSize="14sp"
                        android:textColor="#2563EB"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvAciklama"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Açıklama"
                        android:textSize="14sp"
                        android:textColor="#64748B"
                        android:layout_marginTop="12dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Şartlar Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Şartlar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="16dp" />

                    <!-- Eğitim -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Eğitim Seviyesi"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvEgitimSeviyesi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lisans (4 Yıllık) Mezunu"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- KPSS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KPSS Şartı"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvKpssSarti"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Minimum 60 Puan"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Aranan Bölümler -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aranan Bölümler"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvArananBolumler"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Herhangi Bir Bölüm"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Görev Yeri -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Görev Yeri"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvGorevYeri"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tüm Türkiye"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Yaş -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Yaş Şartı"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvYasSarti"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="18-30 Yaş Arası"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Cinsiyet -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cinsiyet"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvCinsiyet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kadın ve Erkek"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Ehliyet -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ehliyet"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvEhliyet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ehliyet Gerekmiyor"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" />

                    <!-- Ek Şartlar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ek Şartlar"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvEkSartlar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Boy-Kilo Şartı"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Başvuru Tarihleri Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Başvuru Tarihleri"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Başlangıç"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvBasvuruBaslangic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01 Ocak 2024"
                                android:textSize="16sp"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bitiş"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvBasvuruBitis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 Ocak 2024"
                                android:textSize="16sp"
                                android:textColor="#DC2626"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Durum"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:id="@+id/tvKalanGunDetay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 gün kaldı"
                                android:textSize="16sp"
                                android:textColor="#059669"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Linkler Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bağlantılar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="16dp" />

                    <!-- Yayınlanma Adresi -->
                    <LinearLayout
                        android:id="@+id/layoutYayinlanmaAdresi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:background="#F1F5F9"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Resmi İlan Adresi"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detaylı bilgi için tıklayın →"
                                android:textSize="14sp"
                                android:textColor="#2563EB"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Başvuru Linki -->
                    <LinearLayout
                        android:id="@+id/layoutBasvuruLinki"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:background="#EFF6FF"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_send"
                            android:tint="#2563EB" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Başvuru Adresi"
                                android:textSize="12sp"
                                android:textColor="#64748B" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Başvuru yapmak için tıklayın →"
                                android:textSize="14sp"
                                android:textColor="#2563EB"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Butonlar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBasvurdum"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Başvurdum"
                    android:textColor="#64748B"
                    app:backgroundTint="#F1F5F9"
                    app:cornerRadius="12dp"
                    app:strokeColor="#CBD5E1"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBasvuruyaGit"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="2"
                    android:layout_marginStart="12dp"
                    android:text="Başvuruya Git"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#2563EB"
                    app:cornerRadius="12dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
